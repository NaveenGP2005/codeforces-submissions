#include <bits/stdc++.h>
using namespace std;
        queue<int>mq,q;
 
void dfs(int u,vector<vector<int>>&g,vector<int>&c,vector<int>&ans){
    c[u]=1;
    ans[u]=1;
    
    for(int v:g[u]){
        if(c[v]==0) dfs(v,g,c,ans);
        else if(c[v]==1) q.push(v);
        else mq.push(v);
    }
    c[u]=2;
}
 
int main(){
    ios::sync_with_stdio(0);
    cin.tie(0);
 
    int t;cin>>t;
    while(t--){
        int n,m;
        cin>>n>>m;
        
        vector<vector<int>>g(n+1);
        for(int i=0;i<m;i++){
            int u,v;
            cin>>u>>v;
            g[u].push_back(v);
        }
        
        
        vector<int>c(n+1,0),ans(n+1,0);
        dfs(1,g,c,ans);
        
        while(mq.size()){
            int u=mq.front();
            mq.pop();
            
            if(ans[u]==2) continue;
            ans[u]=2;
            
            for(int v:g[u]){
                if(ans[v]==1) mq.push(v);
            }
        }
        
        while(q.size()){
            int u=q.front();
            q.pop();
            if(ans[u]==-1) continue;
            ans[u]=-1;
            
            for(int v:g[u]){
                if(ans[v]!=-1) q.push(v);
            }
        }
        
        for(int i=1;i<=n;i++) cout<<ans[i]<<" ";
        cout<<endl;
        
        
    }
    return 0;
}